// This is the Prisma schema file.
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER
  TEAM_ADMIN
}

enum TeamMemberRole {
  OWNER
  ADMIN
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players             Player[]
  surveys             Survey[]
  tags                Tag[]
  kioskSettings       KioskSettings[]
  memberships         TeamMembership[]
  invites             Invite[]
  adminAccess         AdminAccessSettings?
  opsTablePreferences OpsTablePreference[]
  opsRules            OpsRule[]
  opsInterventions    OpsIntervention[]

  @@map("teams")
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(TEAM_ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships         TeamMembership[]
  invitesSent         Invite[]              @relation("InvitesSent")
  opsTablePreferences OpsTablePreference[]

  @@map("admin_users")
}

/// Per-team + per-admin Live Ops table layout + per-survey question maps.
model OpsTablePreference {
  id          String   @id @default(cuid())
  teamId      String
  adminUserId String
  /// JSON: { bySurvey: { [surveyId]: OpsColumnConfig[] }, columns?: OpsColumnConfig[] }
  columns     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([teamId, adminUserId])
  @@index([adminUserId])
  @@map("ops_table_preferences")
}

/// Admin-configurable Live Ops intervention rule (per team).
model OpsRule {
  id        String   @id @default(cuid())
  teamId    String
  /// Optional: limit rule to one survey; null = any survey on the team
  surveyId  String?
  name      String
  /// readiness | fatigue | soreness | sleepQuality | mood | stress | sleepRisk | painMax | pending
  metric    String
  /// LT | LTE | GT | GTE | EQ
  operator  String
  threshold Float
  /// WATCH | ALERT | CRITICAL
  severity  String   @default("WATCH")
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team          Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  interventions OpsIntervention[]

  @@index([teamId])
  @@index([teamId, enabled])
  @@map("ops_rules")
}

/// Fired rule instance for a player on a calendar day.
model OpsIntervention {
  id             String    @id @default(cuid())
  teamId         String
  surveyId       String?
  ruleId         String
  playerId       String
  /// YYYY-MM-DD
  date           String
  severity       String
  metric         String
  value          Float?
  message        String
  /// OPEN | ACKNOWLEDGED | RESOLVED
  status         String    @default("OPEN")
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  acknowledgedAt DateTime?
  resolvedAt     DateTime?

  team Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  rule OpsRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, playerId, date])
  @@index([teamId, date])
  @@index([teamId, status])
  @@map("ops_interventions")
}

model TeamMembership {
  id          String         @id @default(cuid())
  teamId      String
  adminUserId String
  role        TeamMemberRole @default(OWNER)
  createdAt   DateTime       @default(now())

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([teamId, adminUserId])
  @@index([adminUserId])
  @@map("team_memberships")
}

model Invite {
  id              String       @id @default(cuid())
  email           String
  token           String       @unique
  status          InviteStatus @default(PENDING)
  invitedById     String
  /// Optional suggested team name shown on accept form
  suggestedTeamName String?
  acceptedTeamId  String?
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  acceptedAt      DateTime?

  invitedBy    AdminUser @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedTeam Team?     @relation(fields: [acceptedTeamId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@map("invites")
}

model Player {
  id          String    @id @default(cuid())
  /// Set for all rows after multi-admin migration (Football Club / new teams)
  teamId      String?
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  email       String?
  phone       String?
  image       String? // URL to player photo
  password    String    @default("") // Password based on initials (e.g., "AB" for Aleksa Boskovic)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team      Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  responses Response[]

  @@unique([teamId, email])
  @@index([teamId])
  @@map("players")
}

model Survey {
  id          String   @id @default(cuid())
  teamId      String?
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String // Admin user id or legacy identifier

  // Recurring survey fields
  isRecurring    Boolean   @default(false)
  startDate      DateTime?
  endDate        DateTime?
  dailyStartTime String? // Format: "06:00"
  dailyEndTime   String? // Format: "11:00"
  timezone       String    @default("Europe/Belgrade")

  // Session / match-day tagging (per-survey opt-in, used mainly for RPE)
  trackSessionType Boolean @default(false)
  trackMatchDay    Boolean @default(false)

  team      Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  questions Question[]
  responses Response[]

  @@index([teamId])
  @@map("surveys")
}

model Question {
  id         String       @id @default(cuid())
  surveyId   String
  text       String
  type       QuestionType
  options    String? // JSON string for multiple choice options
  required   Boolean      @default(true)
  order      Int          @default(0)
  createdAt  DateTime     @default(now())

  survey  Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("questions")
}

model Response {
  id          String   @id @default(cuid())
  surveyId    String
  playerId    String? // Link to registered player
  playerName  String? // Optional player identifier (for anonymous responses)
  playerEmail String? // Optional player email (for anonymous responses)
  submittedAt DateTime @default(now())

  // Snapshot labels (stored as text so renaming/deleting a Tag never corrupts history)
  sessionType String? // e.g. "Gym", "Pitch", "Rehab"
  matchDay    String? // e.g. "MD", "MD-1", "MD+1"

  survey  Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  player  Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  answers Answer[]

  @@index([surveyId, submittedAt])
  @@index([surveyId, playerId, submittedAt])
  @@map("responses")
}

model Answer {
  id         String @id @default(cuid())
  responseId String
  questionId String
  value      String // Store answer as string (can be JSON for complex answers)

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@map("answers")
}

model KioskSettings {
  id               String   @id @default(cuid())
  teamId           String?
  password         String   @default("")
  coachPassword    String   @default("")
  isEnabled        Boolean  @default(false)
  theme            String   @default("dark")
  clubName         String   @default("")
  clubLogo         String? // data URL or image URL
  showClubBranding Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId])
  @@map("kiosk_settings")
}

/// Password used to exit kiosk mode back to admin (per team).
model AdminAccessSettings {
  id        String   @id @default(cuid())
  teamId    String?  @unique
  password  String   @default("123")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("admin_access_settings")
}

// Coach-managed labels used for tagging RPE sessions.
// category: "SESSION" (Gym/Pitch/Rehab...) or "MATCHDAY" (MD/MD-1/MD+1...)
model Tag {
  id        String   @id @default(cuid())
  teamId    String?
  name      String
  category  String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([category])
  @@map("tags")
}

enum QuestionType {
  TEXT
  NUMBER
  EMAIL
  SELECT
  MULTIPLE_SELECT
  SCALE
  BOOLEAN
  BODY_MAP
  RATING_SCALE
  RPE
  SLIDER
  TIME
}
